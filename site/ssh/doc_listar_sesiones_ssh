####################
Listar sesiones SSH
####################



netstat -tnpa | grep 'ESTABLISHED.*sshd'

ps auxwww | grep sshd:

ps ax | grep sshd

echo $SSH_CONNECTION

cat /var/log/sshd.log | grep hendrenj | grep session

